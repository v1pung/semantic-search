# ── PostgreSQL ──────────────────────────────────────────────────────────────
# Credentials — required in all environments
POSTGRES_USER=semantic
POSTGRES_PASSWORD=semantic
POSTGRES_DB=semantic_search
# Hostname/port — overridden by docker-compose environment: for containers;
# set to localhost for direct local development.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Redis ───────────────────────────────────────────────────────────────────
# Overridden by docker-compose environment: for containers
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Qdrant ──────────────────────────────────────────────────────────────────
# Overridden by docker-compose environment: for containers
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=qa_pairs

# ── Application ─────────────────────────────────────────────────────────────
CSV_PATH=data/qa_pairs.csv
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
SEARCH_TOP_K=5
