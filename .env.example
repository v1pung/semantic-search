# ── PostgreSQL ──────────────────────────────────────────────────────────────
# Credentials — required in all environments
POSTGRES_USER=semantic
POSTGRES_PASSWORD=semantic
POSTGRES_DB=semantic_search
# Hostname/port — overridden by docker-compose environment: for containers;
# set to localhost for direct local development.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Redis ───────────────────────────────────────────────────────────────────
# Overridden by docker-compose environment: for containers
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Qdrant ──────────────────────────────────────────────────────────────────
# Overridden by docker-compose environment: for containers
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=qa_pairs

# ── Application ─────────────────────────────────────────────────────────────
CSV_PATH=data/qa_pairs.csv
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
SEARCH_TOP_K=5

# ── Rate limiting ────────────────────────────────────────────────────────────
# slowapi / limits syntax: "<count>/<period>" where period = second|minute|hour|day
# Examples: "60/minute", "1000/hour", "10/second"
RATE_LIMIT_SEARCH=30/minute
RATE_LIMIT_INGEST=5/minute
# Redis DB index for rate-limit counters (0=broker, 1=backend are used by Celery)
REDIS_RATE_LIMIT_DB=2

# ── Celery ───────────────────────────────────────────────────────────────────
# Seconds before task results are evicted from Redis (default: 1 hour)
CELERY_RESULT_EXPIRES=3600
# Worker process concurrency (override per environment; defaults: dev=2, prod=4)
WORKER_CONCURRENCY=2
# Uvicorn worker count for the prod image (APP_WORKERS only used in prod)
APP_WORKERS=2
